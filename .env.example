PLAIN_API_KEY=plainApiKey_xxx          # Settings -> Machine users -> API key, needs thread:read
NOTION_API_KEY=ntn_xxx                 # Notion integration token, shared with the ticket database
NOTION_DATABASE_ID=xxx                 # from the database URL
PLAIN_WORKSPACE_ID=w_xxx               # from any app.plain.com URL
REDIS_URL=                             # optional; falls back to a local .last_run file
# Optional overrides:
# PLAIN_THREAD_URL_TEMPLATE=https://app.plain.com/workspace/{workspaceId}/thread/{threadId}
# PLAIN_CATEGORY_FIELD_KEY=category
# PLAIN_CATEGORY_LABEL_PREFIX=Category:
# PLAIN_ENG_STATUS_FIELD_KEY=eng_status
# PLAIN_ENG_STATUS_LABEL_PREFIX=Eng:
# SYNC_OVERLAP_MINUTES=60
